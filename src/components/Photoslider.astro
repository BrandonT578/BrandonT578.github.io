---
interface Props {
  photos?: { src: string; alt: string }[];
}

const { photos = [] } = Astro.props;
---

<div class="photo-slider">
  <div class="photo-viewport">
    <div class="photo-track" id="photoTrack">
      {photos.length > 0 ? (
        photos.map((photo) => (
          <div class="photo-slide">
            <img src={photo.src} alt={photo.alt} />
          </div>
        ))
      ) : (
        <>
          <div class="photo-slide">
            <div class="photo-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <p>Photo 1</p>
            </div>
          </div>
          <div class="photo-slide">
            <div class="photo-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <p>Photo 2</p>
            </div>
          </div>
          <div class="photo-slide">
            <div class="photo-placeholder">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <p>Photo 3</p>
            </div>
          </div>
        </>
      )}
    </div>
  </div>

  <div class="photo-controls">
    <button class="photo-btn" id="photoPrev" aria-label="Previous photo">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="photo-dots" id="photoDots"></div>
    <button class="photo-btn" id="photoNext" aria-label="Next photo">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
</div>

<script>
  const track = document.getElementById('photoTrack') as HTMLElement;
  const prevBtn = document.getElementById('photoPrev') as HTMLButtonElement;
  const nextBtn = document.getElementById('photoNext') as HTMLButtonElement;
  const dotsContainer = document.getElementById('photoDots') as HTMLElement;

  const slides = track.querySelectorAll('.photo-slide');
  const total = slides.length;
  let current = 0;

  // Build dots
  slides.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'photo-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', `Go to photo ${i + 1}`);
    dot.addEventListener('click', () => goTo(i));
    dotsContainer.appendChild(dot);
  });

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dotsContainer.querySelectorAll('.photo-dot').forEach((dot, i) => {
      dot.classList.toggle('active', i === current);
    });
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
</script>