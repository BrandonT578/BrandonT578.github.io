---
const pageTitle = "Contact";
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle={pageTitle}>

  <section class="section">
    <div class="container contact-layout">

      <div class="contact-intro">
        <p class="section-label">Get In Touch</p>
        <div class="divider"></div>
        <h1>Let's Connect</h1>
        <p>Whether you have a project idea, a question, or just want to say hello — I'd love to hear from you. I'll get back to you as soon as I can.</p>

        <div class="contact-methods">
          <a href="https://github.com/BrandonT578" target="_blank" rel="noopener" class="contact-method">
            <div class="method-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            </div>
            <div>
              <p class="method-label">GitHub</p>
              <p class="method-value">BrandonT578</p>
            </div>
          </a>

          <div class="contact-method">
            <div class="method-icon">📍</div>
            <div>
              <p class="method-label">Location</p>
              <p class="method-value">Meadville, PA</p>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">🎓</div>
            <div>
              <p class="method-label">School</p>
              <p class="method-value">Allegheny College</p>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap card">
        <h2>Send a Message</h2>
        <p style="margin-bottom:1.5rem; font-size:0.875rem;">Fill out the form and I'll get back to you as soon as I can.</p>

        <div data-fs-success class="form-success">
          ✅ Message sent! I'll get back to you soon.
        </div>
        <div data-fs-error class="form-error"></div>

        <form id="contact-form">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required data-fs-field />
            <span class="field-error" data-fs-error="name"></span>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required data-fs-field />
            <span class="field-error" data-fs-error="email"></span>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="What's this about?" data-fs-field />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Your message..." required data-fs-field></textarea>
            <span class="field-error" data-fs-error="message"></span>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;" data-fs-submit-btn>
            Send Message
          </button>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
  formspree('initForm', { formElement: '#contact-form', formId: 'xwvavnqj' });
</script>
<script src="https://unpkg.com/@formspree/ajax@1" defer></script>