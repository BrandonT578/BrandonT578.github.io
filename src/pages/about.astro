---
const pageTitle = "About";
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoSlider from '../components/Photoslider.astro';
const photos: { src: string; alt: string }[] = [
{ src: "/img/Brandon.JPG", alt: "Description of photo 1" },
{ src: "/img/Brandon.JPG", alt: "Description of photo 2" },
{ src: "/img/Brandon.JPG", alt: "Description of photo 3" },
];;
---
<BaseLayout pageTitle={pageTitle}>

  <!-- About Hero -->
  <section class="section">
    <div class="container about-hero">
      <div class="about-image-col">
        <div class="image-frame">
          <img src="/img/Brandon.JPG" alt="Brandon Thompson" />
        </div>
        <div class="social-bar">
          <a href="https://github.com/BrandonT578" target="_blank" rel="noopener" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="/contact" class="social-link">✉️ Contact</a>
        </div>
      </div>
      <div class="about-text-col">
        <p class="section-label">About Me</p>
        <div class="divider"></div>
        <h1>Brandon Thompson</h1>
        <p class="subtitle">Software Engineering Student @ Allegheny College</p>
        <p>
          I'm a software engineering student with a passion for building thoughtful, user-centered applications. Whether it's a backend API or a polished frontend, I care about writing code that works well and is easy to understand.
        </p>
        <p style="margin-top:1rem;">
          When I'm not coding, I'm exploring new technologies, working on personal projects, and learning everything I can about the craft of software development.
        </p>
        <div class="about-tags">
          <span class="tag">Allegheny College</span>
          <span class="tag">Software Engineering</span>
          <span class="tag">Full Stack</span>
          <span class="tag">Open Source</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Bio + Photo Slider -->
  <section class="section" style="padding-top:0">
    <div class="container bio-slider-layout">

      <div class="bio-body">
        <p class="section-label">Background</p>
        <div class="divider"></div>
        <h2>My Story</h2>
        <p>
          Growing up, I was always the curious kid who wanted to know how things worked. That curiosity eventually led me to software engineering — a field where you can build almost anything from scratch with just a computer and an idea.
        </p>
        <p style="margin-top:1rem;">
          At Allegheny College, I've had the opportunity to work on a wide range of projects — from data structures and algorithms to web development and software design. Each project has pushed me to think more carefully about how I write code and how software can better serve its users.
        </p>
        <p style="margin-top:1rem;">
          I'm always looking for new opportunities to learn and grow. Feel free to check out my projects or reach out — I'd love to connect.
        </p>
        <div style="margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap;">
          <a href="/project" class="btn btn-primary">See My Work</a>
          <a href="/contact" class="btn btn-outline">Say Hello</a>
        </div>
      </div>

      <div class="bio-slider-col">
        <p class="section-label" style="margin-bottom:1rem;">Photos</p>
        <PhotoSlider photos={photos} />
      </div>

    </div>
  </section>

</BaseLayout>