---
const pageTitle = "Projects";
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectSlider from '../components/Projectslider.astro';
---
<BaseLayout pageTitle={pageTitle}>

  <section class="section">
    <div class="container">
      <p class="section-label">My Work</p>
      <div class="divider"></div>
      <h1>Projects</h1>
      <p class="page-intro">A collection of things I've built — personal projects, coursework, and experiments.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <ProjectSlider>

        <div class="slide">
          <div class="slide-image">
            <div class="image-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="slide-body">
            <span class="tag" style="margin-bottom:0.75rem; display:inline-block;">Featured</span>
            <h3>Project Title</h3>
            <p>A detailed description of your most impressive project. Explain what it does, what problem it solves, and what you learned building it.</p>
            <div class="project-tags">
              <span class="tag">Python</span>
              <span class="tag">JavaScript</span>
              <span class="tag">GitHub</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/BrandonT578" class="btn btn-primary" target="_blank">View on GitHub</a>
              <a href="#" class="btn btn-outline">Live Demo</a>
            </div>
          </div>
        </div>

        <div class="slide">
          <div class="slide-image">
            <div class="image-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="slide-body">
            <span class="tag" style="margin-bottom:0.75rem; display:inline-block;">CLI Tool</span>
            <h3>Project One</h3>
            <p>A brief description of what this project does and how you built it. What problem does it solve?</p>
            <div class="project-tags">
              <span class="tag">Python</span>
              <span class="tag">CLI</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/BrandonT578" class="btn btn-primary" target="_blank">View on GitHub</a>
            </div>
          </div>
        </div>

        <div class="slide">
          <div class="slide-image">
            <div class="image-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="slide-body">
            <span class="tag" style="margin-bottom:0.75rem; display:inline-block;">Web</span>
            <h3>Project Two</h3>
            <p>A brief description of what this project does and how you built it. What problem does it solve?</p>
            <div class="project-tags">
              <span class="tag">JavaScript</span>
              <span class="tag">HTML/CSS</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/BrandonT578" class="btn btn-primary" target="_blank">View on GitHub</a>
            </div>
          </div>
        </div>

        <div class="slide">
          <div class="slide-image">
            <div class="image-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="slide-body">
            <span class="tag" style="margin-bottom:0.75rem; display:inline-block;">Portfolio</span>
            <h3>This Portfolio</h3>
            <p>My personal portfolio site built with Astro, showcasing my projects, skills, and experience as a software engineering student.</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">HTML/CSS</span>
            </div>
            <div class="project-links">
              <a href="https://github.com/BrandonT578" class="btn btn-primary" target="_blank">View on GitHub</a>
            </div>
          </div>
        </div>

      </ProjectSlider>
    </div>
  </section>

</BaseLayout>