---
const pageTitle = "Projects";
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle={pageTitle}>
 
  <section class="section">
    <div class="container">
      <p class="section-label">My Work</p>
      <div class="divider"></div>
      <h1>Projects</h1>
      <p class="page-intro">A collection of things I've built — personal projects, coursework, and experiments.</p>
    </div>
  </section>
 
  <!-- Featured Project -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <h2 class="section-heading">Featured</h2>
      <div class="featured-card card">
        <div class="featured-image">
          <div class="image-placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
        </div>
        <div class="featured-text">
          <span class="tag" style="margin-bottom:1rem; display:inline-block;">Featured Project</span>
          <h3>Project Title</h3>
          <p>A detailed description of your most impressive project goes here. Explain what it does, what problem it solves, and what technologies you used to build it.</p>
          <div class="project-tags">
            <span class="tag">Python</span>
            <span class="tag">JavaScript</span>
            <span class="tag">GitHub</span>
          </div>
          <div class="project-links">
            <a href="https://github.com/BrandonT578" class="btn btn-primary" target="_blank">View on GitHub</a>
            <a href="#" class="btn btn-outline">Live Demo</a>
          </div>
        </div>
      </div>
    </div>
  </section>
 
  <!-- All Projects Grid -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <h2 class="section-heading">All Projects</h2>
      <div class="projects-grid">
 
        <div class="project-card card">
          <div class="project-image">
            <div class="image-placeholder small">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="project-body">
            <h3>Project One</h3>
            <p>A brief description of what this project does and how you built it.</p>
            <div class="project-tags">
              <span class="tag">Python</span>
              <span class="tag">CLI</span>
            </div>
            <a href="https://github.com/BrandonT578" class="project-link" target="_blank">View on GitHub →</a>
          </div>
        </div>
 
        <div class="project-card card">
          <div class="project-image">
            <div class="image-placeholder small">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="project-body">
            <h3>Project Two</h3>
            <p>A brief description of what this project does and how you built it.</p>
            <div class="project-tags">
              <span class="tag">JavaScript</span>
              <span class="tag">HTML/CSS</span>
            </div>
            <a href="https://github.com/BrandonT578" class="project-link" target="_blank">View on GitHub →</a>
          </div>
        </div>
 
        <div class="project-card card">
          <div class="project-image">
            <div class="image-placeholder small">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="project-body">
            <h3>Project Three</h3>
            <p>A brief description of what this project does and how you built it.</p>
            <div class="project-tags">
              <span class="tag">Java</span>
              <span class="tag">OOP</span>
            </div>
            <a href="https://github.com/BrandonT578" class="project-link" target="_blank">View on GitHub →</a>
          </div>
        </div>
 
        <div class="project-card card">
          <div class="project-image">
            <div class="image-placeholder small">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="project-body">
            <h3>This Portfolio</h3>
            <p>My personal portfolio site built with Astro, showcasing my projects and experience.</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">HTML/CSS</span>
            </div>
            <a href="https://github.com/BrandonT578" class="project-link" target="_blank">View on GitHub →</a>
          </div>
        </div>
 
      </div>
    </div>
  </section>
 
</BaseLayout>